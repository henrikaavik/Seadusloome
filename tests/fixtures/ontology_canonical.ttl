@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix estleg: <https://data.riik.ee/ontology/estleg#> .

#
# C0 fixture (2026-05-15) — a minimal Turtle graph that exercises every
# canonical predicate from ``app.ontology.relations`` exactly once.
#
# Designed to be loaded into a transient ``rdflib.Graph`` so unit tests
# can prove that:
#
#   1. Each canonical predicate is queryable.
#   2. The impact-engine SELECT templates return the expected rows when
#      seeded with this graph plus a synthetic draft named graph.
#
# Topology (one of each shape):
#
#                ┌──────────────────┐
#                │ CourtDecision_1  │
#                └──────────────────┘
#                         │
#                         │ interpretsLaw / interpretedBy (inverse)
#                         ▼
#   AmendmentEvent_1 ──amends──▶ Provision_1 ──amendedBy──▶ Act_2
#                                    │
#                                    │ requestedCluster / topicCluster
#                                    ▼
#                                Cluster_1
#                                    │
#                                    │ semanticallySimilarTo
#                                    ▼
#                                Provision_2
#
#   Provision_1 ──transposesDirective──▶ EU_Dir_1 ──transposedBy──▶ Act_1
#   Provision_1 ──harmonisedWith──▶ EU_Dir_1
#   Provision_1 ──references──▶ Provision_3
#   Provision_1 ──definesConcept──▶ Concept_1
#   Provision_1 ──definesTerm──▶ Term_1
#   Provision_1 ──competentAuthority──▶ Institution_1
#

# ---------------------------------------------------------------------------
# Entities (just enough types + labels to make label-projecting queries work)
# ---------------------------------------------------------------------------

estleg:Provision_1 a estleg:LegalProvision ;
    rdfs:label "Provision 1 — fixture" ;
    estleg:sourceAct estleg:Act_1 ;
    estleg:paragrahv "1" .

estleg:Provision_2 a estleg:LegalProvision ;
    rdfs:label "Provision 2 — similar" ;
    estleg:sourceAct estleg:Act_2 ;
    estleg:paragrahv "2" .

estleg:Provision_3 a estleg:LegalProvision ;
    rdfs:label "Provision 3 — referenced" ;
    estleg:sourceAct estleg:Act_1 ;
    estleg:paragrahv "3" .

estleg:Act_1 a estleg:Act ;
    rdfs:label "Act 1 — fixture host" .

estleg:Act_2 a estleg:Act ;
    rdfs:label "Act 2 — amender" .

estleg:CourtDecision_1 a estleg:CourtDecision ;
    rdfs:label "Court Decision 1" ;
    estleg:caseNumber "3-1-1-63-15" ;
    estleg:decisionDate "2015-11-30" ;
    estleg:court estleg:Court_Riigikohus .

estleg:CourtDecision_2 a estleg:CourtDecision ;
    rdfs:label "Court Decision 2 — newer Riigikohus" ;
    estleg:caseNumber "3-1-1-10-20" ;
    estleg:decisionDate "2020-06-12" ;
    estleg:court estleg:Court_Riigikohus ;
    estleg:interpretsLaw estleg:Provision_1 .

estleg:CourtDecision_3 a estleg:EUCourtDecision ;
    rdfs:label "EU Court Decision 1" ;
    estleg:caseNumber "C-131/12" ;
    estleg:decisionDate "2014-05-13" ;
    estleg:court estleg:Court_EuroopaKohus ;
    estleg:interpretsLaw estleg:Provision_1 .

estleg:Court_Riigikohus a estleg:Court ;
    rdfs:label "Riigikohus" .

estleg:Court_EuroopaKohus a estleg:Court ;
    rdfs:label "Euroopa Kohus" .

estleg:AmendmentEvent_1 a estleg:AmendmentEvent ;
    rdfs:label "Amendment Event 1" .

estleg:EU_Dir_1 a estleg:EULegislation ;
    rdfs:label "EU Directive 1" .

estleg:EU_Dir_2 a estleg:EULegislation ;
    rdfs:label "EU Directive 2 — act-level transposition" .

estleg:Cluster_1 a estleg:TopicCluster ;
    rdfs:label "Topic Cluster 1" .

estleg:Concept_1 a estleg:LegalConcept ;
    rdfs:label "Concept 1" .

estleg:Term_1 a estleg:Term ;
    rdfs:label "Term 1" .

estleg:Institution_1 a estleg:Institution ;
    rdfs:label "Institution 1" .

# Two extra Institutions (A3 — Pädevuste kaardistus) so the competence
# overlap query has at least one provision with multiple competent
# authorities. Institution_2 names a recognisable agency-style body so
# the label-search test can exercise CONTAINS/LCASE filtering.
estleg:Institution_2 a estleg:Institution ;
    rdfs:label "Andmekaitse Inspektsioon" .

estleg:Institution_3 a estleg:Institution ;
    rdfs:label "Tarbijakaitse ja Tehnilise Järelevalve Amet" .

# A second provision attached to Act_1 so the A3 by-act bucketing has
# more than one row per act on at least one bucket. ``sourceAct`` is
# carried as a **literal title** to mirror the prod shape (the
# 2026-05-18 Wave 2 spike confirmed ``sourceAct`` is always a string
# literal in the deployed corpus, never a URI). The legacy ``partOf``
# URI edge is kept so older tests that may still reference it via
# direct rdflib queries don't break, but the A1/A3 SPARQL templates
# join on the literal.
estleg:Provision_4 a estleg:LegalProvision ;
    rdfs:label "Provision 4 — Institution_2 competence" ;
    estleg:partOf estleg:Act_1 ;
    estleg:sourceAct "Act 1 — fixture host" ;
    estleg:paragrahv "4" .

# Two more provisions for A3 — one with a single competent authority
# (Institution_2), one with two competent authorities (Institution_2 +
# Institution_3) to exercise the overlap query.
estleg:Provision_5 a estleg:LegalProvision ;
    rdfs:label "Provision 5 — overlap on Institution_2" ;
    estleg:partOf estleg:Act_2 ;
    estleg:sourceAct "Act 2 — amender" ;
    estleg:paragrahv "5" .

# Reified Competence node — present so future v2 queries that need
# Competence's structure (institution / competenceType /
# appliesToProvision / appliesToProvisionCount per the audit) can be
# unit-tested without re-touching the fixture. v1 does **not** depend
# on this node.
estleg:Competence_1 a estleg:Competence ;
    rdfs:label "Competence 1 — Institution_2 over Provision_4" ;
    estleg:institution estleg:Institution_2 ;
    estleg:competenceType "supervisory" ;
    estleg:appliesToProvision estleg:Provision_4 ;
    estleg:appliesToProvisionCount 1 .

# ---------------------------------------------------------------------------
# Canonical relation edges — one per predicate
# ---------------------------------------------------------------------------

# Interpretation (court decisions) — both directions present so the
# impact query's UNION covers either-side data.
estleg:CourtDecision_1 estleg:interpretsLaw estleg:Provision_1 .
estleg:Provision_1     estleg:interpretedBy estleg:CourtDecision_1 .

# Amendments.
estleg:AmendmentEvent_1 estleg:amends    estleg:Provision_1 .
estleg:Provision_1      estleg:amendedBy estleg:Act_2 .

# Topic clustering — populated edge is ``requestedCluster``; ``topicCluster``
# is the SHACL alias (queried for forward compatibility).
estleg:Provision_1 estleg:requestedCluster estleg:Cluster_1 .
estleg:Provision_2 estleg:topicCluster     estleg:Cluster_1 .

# Step 5A live-deploy follow-up: prod has hundreds of ``estleg:Law``
# instances that are actually *topic-map clusters* (``ALKS_Map_2026``,
# ``RKIOMPU1974_Map_2026``, …) — used as overly-broad ``requestedCluster``
# targets and fan out the AFFECTED_ENTITIES query to 500+ unrelated rows.
# We replicate that shape here so the AFFECTED_ENTITIES query's
# ``FILTER NOT EXISTS { ?entity a estleg:Law }`` is regression-tested
# against the canonical fixture, not just unit-mocked.
estleg:TopicMapLaw_1 a estleg:Law ;
    rdfs:label "Mõni teemakaardistus (1974)" .

estleg:Provision_1 estleg:requestedCluster estleg:TopicMapLaw_1 .

# EU transposition + harmonisation.
#
# Per the ontology audit (section 2.5 of the plan), ``transposesDirective`` is
# canonical on Estonian *Act* → EULegislation, but SHACL (lines 62-66 + 158-163)
# also allows it on Provision-level. Both shapes are tested below:
#
#   EU_Dir_1 — Provision-level (direct edge on Provision_1)
#   EU_Dir_2 — Act-level (edge on Act_1; Provision_1 is part of Act_1 via sourceAct)
#
# The impact query must surface BOTH via the appropriate UNION arm.
estleg:Provision_1 estleg:transposesDirective estleg:EU_Dir_1 .
estleg:EU_Dir_1    estleg:transposedBy        estleg:Act_1 .
estleg:Provision_1 estleg:harmonisedWith      estleg:EU_Dir_1 .

estleg:Act_1       estleg:transposesDirective estleg:EU_Dir_2 .

# References / similarity.
#
# A5 (similarity workflow): the ``semanticallySimilarTo`` predicate has
# an inline ``similarityScore`` literal on the *subject* in the populated
# corpus (per the keyword_jaccard v2 pipeline). The A5 SPARQL helper
# projects both the related provision URI and the optional score; rows
# without a score still surface (treated as no-score in the merge layer).
#
# Two edges from Provision_1 — one scored (Provision_2) and one to
# Provision_3 carried via a second subject (Provision_2 → Provision_3,
# unscored) so the helper has both a scored and an unscored row in scope
# when seeded from Provision_2.
estleg:Provision_1 estleg:references             estleg:Provision_3 .
estleg:Provision_1 estleg:semanticallySimilarTo  estleg:Provision_2 ;
                   estleg:similarityScore        "0.82"^^xsd:decimal .

# Concepts / terms.
estleg:Provision_1 estleg:definesConcept estleg:Concept_1 .
estleg:Provision_1 estleg:definesTerm    estleg:Term_1 .

# Competence.
estleg:Provision_1 estleg:competentAuthority estleg:Institution_1 .

# ---------------------------------------------------------------------------
# A2 — Halduskoormus: NormativeType class + individuals + edges
# ---------------------------------------------------------------------------
#
# Four canonical individuals of estleg:NormativeType (one per deontic
# category) plus normativeType + dutyHolder edges on each existing
# provision so the A2 burden helpers can be tested end-to-end against
# this fixture.

estleg:NormativeType a rdfs:Class ;
    rdfs:label "Normatiivne liik" .

estleg:NormType_Obligation  a estleg:NormativeType ; rdfs:label "Kohustus" .
estleg:NormType_Right       a estleg:NormativeType ; rdfs:label "Õigus" .
estleg:NormType_Permission  a estleg:NormativeType ; rdfs:label "Luba" .
estleg:NormType_Prohibition a estleg:NormativeType ; rdfs:label "Keeld" .

# Provision_1 — Obligation, dutyHolder = "Tööandja"
estleg:Provision_1
    estleg:normativeType estleg:NormType_Obligation ;
    estleg:dutyHolder    "Tööandja" .

# Provision_2 — Right, dutyHolder = "Töötaja"
estleg:Provision_2
    estleg:normativeType estleg:NormType_Right ;
    estleg:dutyHolder    "Töötaja" .

# Provision_3 — Prohibition, dutyHolder = "Tööandja"
estleg:Provision_3
    estleg:normativeType estleg:NormType_Prohibition ;
    estleg:dutyHolder    "Tööandja" .

# A3 — Pädevuste kaardistus: extra competentAuthority edges so the
# institution-level queries return non-trivial rows.
#
#   Provision_4 → Institution_2          (single competence, Act_1)
#   Provision_5 → Institution_2          (single competence, Act_2)
#   Provision_5 → Institution_3          (overlap with Institution_2)
#
# Net: Institution_2 holds 2 powers across 2 acts and overlaps with
# Institution_3 on Provision_5. Institution_3 holds 1 power.
estleg:Provision_4 estleg:competentAuthority estleg:Institution_2 .
estleg:Provision_5 estleg:competentAuthority estleg:Institution_2 .
estleg:Provision_5 estleg:competentAuthority estleg:Institution_3 .

# ---------------------------------------------------------------------------
# A4 — Temporal validity (Ajalooline kehtivus)
# ---------------------------------------------------------------------------
#
# Act-level temporal envelope on Act_1 (jõustumine + viimane muudatus
# + hetkestaatus). The AmendmentEvent already exists above
# (estleg:AmendmentEvent_1 amends estleg:Provision_1); we extend it
# with date / rtReference literals so the A4 timeline query has
# something to render.

estleg:Act_1 estleg:entryIntoForce    "2010-01-01"^^xsd:date ;
             estleg:lastAmendmentDate "2023-03-15"^^xsd:date ;
             estleg:temporalStatus    "in_force" .

estleg:AmendmentEvent_1 estleg:eventDate          "2023-03-15"^^xsd:date ;
                        estleg:entryIntoForceDate "2023-04-01"^^xsd:date ;
                        estleg:rtReference        "RT I, 04.01.2023, 12" .

# Court decision date so the interpretation row carries an
# orderable date.
estleg:CourtDecision_1 estleg:decisionDate "2022-06-10"^^xsd:date .

# A pending DraftLegislation that amends Provision_1 — the forward
# look section. ``submittedDate`` carries the date the draft was
# submitted to the Riigikogu.
estleg:Draft_1 a estleg:DraftLegislation ;
    rdfs:label "Eelnõu 1 — fixture" ;
    estleg:amends        estleg:Provision_1 ;
    estleg:submittedDate "2024-02-20"^^xsd:date .

# Wave 2 Step 5A (docs/2026-05-18-bugfix-plan.md, P2 review
# follow-up): a sample ``estleg:referencesAct "<title>"`` literal
# edge. The resolver writes this whenever the act half of a reference
# resolves but the § cannot be pinned (the act-level partial-match
# state). The literal edge is intentionally NON-traversable — the
# impact engine's AFFECTED_ENTITIES query surfaces it as an
# affected-list row but no BFS hop fans out from a string literal.
# The fixture loadability check (test_ontology_relations.py) ensures
# every predicate in LEGAL_PHRASES has at least one triple here.
estleg:Draft_1 estleg:referencesAct "Riigieelarve seadus" .

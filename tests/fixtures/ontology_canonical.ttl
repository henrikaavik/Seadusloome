@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix estleg: <https://data.riik.ee/ontology/estleg#> .

#
# C0 fixture (2026-05-15) вҖ” a minimal Turtle graph that exercises every
# canonical predicate from ``app.ontology.relations`` exactly once.
#
# Designed to be loaded into a transient ``rdflib.Graph`` so unit tests
# can prove that:
#
#   1. Each canonical predicate is queryable.
#   2. The impact-engine SELECT templates return the expected rows when
#      seeded with this graph plus a synthetic draft named graph.
#
# Topology (one of each shape):
#
#                в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
#                в”Ӯ CourtDecision_1  в”Ӯ
#                в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
#                         в”Ӯ
#                         в”Ӯ interpretsLaw / interpretedBy (inverse)
#                         в–ј
#   AmendmentEvent_1 в”Җв”Җamendsв”Җв”Җв–¶ Provision_1 в”Җв”ҖamendedByв”Җв”Җв–¶ Act_2
#                                    в”Ӯ
#                                    в”Ӯ requestedCluster / topicCluster
#                                    в–ј
#                                Cluster_1
#                                    в”Ӯ
#                                    в”Ӯ semanticallySimilarTo
#                                    в–ј
#                                Provision_2
#
#   Provision_1 в”Җв”ҖtransposesDirectiveв”Җв”Җв–¶ EU_Dir_1 в”Җв”ҖtransposedByв”Җв”Җв–¶ Act_1
#   Provision_1 в”Җв”ҖharmonisedWithв”Җв”Җв–¶ EU_Dir_1
#   Provision_1 в”Җв”Җreferencesв”Җв”Җв–¶ Provision_3
#   Provision_1 в”Җв”ҖdefinesConceptв”Җв”Җв–¶ Concept_1
#   Provision_1 в”Җв”ҖdefinesTermв”Җв”Җв–¶ Term_1
#   Provision_1 в”Җв”ҖcompetentAuthorityв”Җв”Җв–¶ Institution_1
#

# ---------------------------------------------------------------------------
# Entities (just enough types + labels to make label-projecting queries work)
# ---------------------------------------------------------------------------

estleg:Provision_1 a estleg:LegalProvision ;
    rdfs:label "Provision 1 вҖ” fixture" ;
    estleg:sourceAct estleg:Act_1 ;
    estleg:paragrahv "1" .

estleg:Provision_2 a estleg:LegalProvision ;
    rdfs:label "Provision 2 вҖ” similar" ;
    estleg:sourceAct estleg:Act_2 ;
    estleg:paragrahv "2" .

estleg:Provision_3 a estleg:LegalProvision ;
    rdfs:label "Provision 3 вҖ” referenced" ;
    estleg:sourceAct estleg:Act_1 ;
    estleg:paragrahv "3" .

estleg:Act_1 a estleg:Act ;
    rdfs:label "Act 1 вҖ” fixture host" .

estleg:Act_2 a estleg:Act ;
    rdfs:label "Act 2 вҖ” amender" .

estleg:CourtDecision_1 a estleg:CourtDecision ;
    rdfs:label "Court Decision 1" .

estleg:AmendmentEvent_1 a estleg:AmendmentEvent ;
    rdfs:label "Amendment Event 1" .

estleg:EU_Dir_1 a estleg:EULegislation ;
    rdfs:label "EU Directive 1" .

estleg:EU_Dir_2 a estleg:EULegislation ;
    rdfs:label "EU Directive 2 вҖ” act-level transposition" .

estleg:Cluster_1 a estleg:TopicCluster ;
    rdfs:label "Topic Cluster 1" .

estleg:Concept_1 a estleg:LegalConcept ;
    rdfs:label "Concept 1" .

estleg:Term_1 a estleg:Term ;
    rdfs:label "Term 1" .

estleg:Institution_1 a estleg:Institution ;
    rdfs:label "Institution 1" .

# Two extra Institutions (A3 вҖ” PГӨdevuste kaardistus) so the competence
# overlap query has at least one provision with multiple competent
# authorities. Institution_2 names a recognisable agency-style body so
# the label-search test can exercise CONTAINS/LCASE filtering.
estleg:Institution_2 a estleg:Institution ;
    rdfs:label "Andmekaitse Inspektsioon" .

estleg:Institution_3 a estleg:Institution ;
    rdfs:label "Tarbijakaitse ja Tehnilise JГӨrelevalve Amet" .

# A second provision attached to Act_1 so the A3 by-act bucketing has
# more than one row per act on at least one bucket.
estleg:Provision_4 a estleg:LegalProvision ;
    rdfs:label "Provision 4 вҖ” Institution_2 competence" ;
    estleg:partOf estleg:Act_1 ;
    estleg:paragrahv "4" .

# Two more provisions for A3 вҖ” one with a single competent authority
# (Institution_2), one with two competent authorities (Institution_2 +
# Institution_3) to exercise the overlap query.
estleg:Provision_5 a estleg:LegalProvision ;
    rdfs:label "Provision 5 вҖ” overlap on Institution_2" ;
    estleg:partOf estleg:Act_2 ;
    estleg:paragrahv "5" .

# Reified Competence node вҖ” present so future v2 queries that need
# Competence's structure (institution / competenceType /
# appliesToProvision / appliesToProvisionCount per the audit) can be
# unit-tested without re-touching the fixture. v1 does **not** depend
# on this node.
estleg:Competence_1 a estleg:Competence ;
    rdfs:label "Competence 1 вҖ” Institution_2 over Provision_4" ;
    estleg:institution estleg:Institution_2 ;
    estleg:competenceType "supervisory" ;
    estleg:appliesToProvision estleg:Provision_4 ;
    estleg:appliesToProvisionCount 1 .

# ---------------------------------------------------------------------------
# Canonical relation edges вҖ” one per predicate
# ---------------------------------------------------------------------------

# Interpretation (court decisions) вҖ” both directions present so the
# impact query's UNION covers either-side data.
estleg:CourtDecision_1 estleg:interpretsLaw estleg:Provision_1 .
estleg:Provision_1     estleg:interpretedBy estleg:CourtDecision_1 .

# Amendments.
estleg:AmendmentEvent_1 estleg:amends    estleg:Provision_1 .
estleg:Provision_1      estleg:amendedBy estleg:Act_2 .

# Topic clustering вҖ” populated edge is ``requestedCluster``; ``topicCluster``
# is the SHACL alias (queried for forward compatibility).
estleg:Provision_1 estleg:requestedCluster estleg:Cluster_1 .
estleg:Provision_2 estleg:topicCluster     estleg:Cluster_1 .

# EU transposition + harmonisation.
#
# Per the ontology audit (section 2.5 of the plan), ``transposesDirective`` is
# canonical on Estonian *Act* вҶ’ EULegislation, but SHACL (lines 62-66 + 158-163)
# also allows it on Provision-level. Both shapes are tested below:
#
#   EU_Dir_1 вҖ” Provision-level (direct edge on Provision_1)
#   EU_Dir_2 вҖ” Act-level (edge on Act_1; Provision_1 is part of Act_1 via sourceAct)
#
# The impact query must surface BOTH via the appropriate UNION arm.
estleg:Provision_1 estleg:transposesDirective estleg:EU_Dir_1 .
estleg:EU_Dir_1    estleg:transposedBy        estleg:Act_1 .
estleg:Provision_1 estleg:harmonisedWith      estleg:EU_Dir_1 .

estleg:Act_1       estleg:transposesDirective estleg:EU_Dir_2 .

# References / similarity.
estleg:Provision_1 estleg:references            estleg:Provision_3 .
estleg:Provision_1 estleg:semanticallySimilarTo estleg:Provision_2 .

# Concepts / terms.
estleg:Provision_1 estleg:definesConcept estleg:Concept_1 .
estleg:Provision_1 estleg:definesTerm    estleg:Term_1 .

# Competence.
estleg:Provision_1 estleg:competentAuthority estleg:Institution_1 .

# A3 вҖ” PГӨdevuste kaardistus: extra competentAuthority edges so the
# institution-level queries return non-trivial rows.
#
#   Provision_4 вҶ’ Institution_2          (single competence, Act_1)
#   Provision_5 вҶ’ Institution_2          (single competence, Act_2)
#   Provision_5 вҶ’ Institution_3          (overlap with Institution_2)
#
# Net: Institution_2 holds 2 powers across 2 acts and overlaps with
# Institution_3 on Provision_5. Institution_3 holds 1 power.
estleg:Provision_4 estleg:competentAuthority estleg:Institution_2 .
estleg:Provision_5 estleg:competentAuthority estleg:Institution_2 .
estleg:Provision_5 estleg:competentAuthority estleg:Institution_3 .
